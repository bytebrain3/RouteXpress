{
  "name": "routexpress-bd",
  "version": "1.0.1",
  "description": "A TypeScript/JavaScript library for integrating Steadfast Pathao REDX delivery services in Bangladesh",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./controllers/steadfast": {
      "import": {
        "types": "./dist/controllers/steadfast/index.d.ts",
        "default": "./dist/controllers/steadfast/index.js"
      },
      "require": {
        "types": "./dist/controllers/steadfast/index.d.ts",
        "default": "./dist/controllers/steadfast/index.js"
      }
    },
    "./controllers/pathao": {
      "import": {
        "types": "./dist/controllers/pathao/index.d.ts",
        "default": "./dist/controllers/pathao/index.js"
      },
      "require": {
        "types": "./dist/controllers/pathao/index.d.ts",
        "default": "./dist/controllers/pathao/index.js"
      }
    },
    "./controllers/redx": {
      "import": {
        "types": "./dist/controllers/redx/index.d.ts",
        "default": "./dist/controllers/redx/index.js"
      },
      "require": {
        "types": "./dist/controllers/redx/index.d.ts",
        "default": "./dist/controllers/redx/index.js"
      }
    },
    "./controllers/webhooks": {
      "import": {
        "types": "./dist/controllers/webhooks/index.d.ts",
        "default": "./dist/controllers/webhooks/index.js"
      },
      "require": {
        "types": "./dist/controllers/webhooks/index.d.ts",
        "default": "./dist/controllers/webhooks/index.js"
      }
    },
    "./types/*": {
      "import": {
        "types": "./dist/types/*.d.ts",
        "default": "./dist/types/*.js"
      },
      "require": {
        "types": "./dist/types/*.d.ts",
        "default": "./dist/types/*.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "prepublishOnly": "npm run build",
    "test": "node --loader ts-node/esm test/main.ts",
    "start": "ts-node test/main.ts"
  },
  "keywords": [
    "delivery",
    "steadfast",
    "pathao",
    "redx",
    "delivery-service",
    "delivery-api",
    "delivery-management",
    "logistics-api",
    "logistics-management",
    "logistics",
    "bangladesh",
    "courier",
    "webhook"
  ],
  "author": "Dip",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bytebrain3/RouteXpress.git"
  },
  "packageManager": "pnpm@10.7.1",
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsc-alias": "^1.8.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  }
}
